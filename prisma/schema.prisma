generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String               @id @default(uuid())
  legacyId             Int?                 @unique @map("legacy_id")
  name                 String
  email                String               @unique
  taxIdentifier        String               @unique @map("tax_identifier")
  password             String
  role                 Role
  department           Department
  isActive             Boolean              @default(true) @map("is_active")
  isFirstAccess        Boolean              @default(true) @map("is_first_access")
  isDeleted            Boolean              @default(false) @map("is_deleted")
  locationId           String?              @map("location_id")
  phone                String?
  mobile               String?
  extension            String?
  photo                String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  deletedAt            DateTime?            @map("deleted_at")
  location             Location?            @relation(fields: [locationId], references: [id])
  serviceOrders        ServiceOrder[]
  serviceOrderStatuses ServiceOrderStatus[]
  historics            Historic[]
  patrimoniesCreated   Patrimony[]          @relation("PatrimonyCreatedBy")
  patrimoniesUpdated   Patrimony[]          @relation("PatrimonyUpdatedBy")
  serviceOrdersClosed  ServiceOrder[]       @relation("ServiceOrderClosedBy")
  serviceOrdersLab     ServiceOrder[]       @relation("ServiceOrderLabTechnician")

  @@map("users")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  email     String
  used      Boolean  @default(false)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

model LocationType {
  id        String     @id @default(uuid())
  legacyId  Int?       @unique @map("legacy_id")
  name      String
  locations Location[]

  @@map("location_types")
}

model Location {
  id             String       @id @default(uuid())
  legacyId       Int?         @unique @map("legacy_id")
  name           String
  address        String?
  directorate    String?
  phone          String?
  mobile         String?
  department     Department
  locationTypeId String       @map("location_type_id")
  locationType   LocationType @relation(fields: [locationTypeId], references: [id])
  users          User[]
  patrimonies    Patrimony[]

  @@map("locations")
}

model PatrimonyType {
  id          String      @id @default(uuid())
  legacyId    Int?        @unique @map("legacy_id")
  name        String
  patrimonies Patrimony[]

  @@map("patrimony_types")
}

model Patrimony {
  id              String             @id @default(uuid())
  legacyId        Int?               @unique @map("legacy_id")
  inventoryNumber String             @map("inventory_number")
  description     String
  situation       PatrimonySituation
  locationName    String?            @map("location_name")
  department      Department
  locationId      String             @map("location_id")
  patrimonyTypeId String             @map("patrimony_type_id")
  createdById     String?            @map("created_by_id")
  updatedById     String?            @map("updated_by_id")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  isDeleted       Boolean            @default(false) @map("is_deleted")
  deletedAt       DateTime?          @map("deleted_at")
  location        Location           @relation(fields: [locationId], references: [id])
  patrimonyType   PatrimonyType      @relation(fields: [patrimonyTypeId], references: [id])
  createdBy       User?              @relation("PatrimonyCreatedBy", fields: [createdById], references: [id])
  updatedBy       User?              @relation("PatrimonyUpdatedBy", fields: [updatedById], references: [id])
  serviceOrders   ServiceOrder[]

  @@map("patrimonies")
}

model ReportedIssue {
  id            String         @id @default(uuid())
  legacyId      Int?           @unique @map("legacy_id")
  name          String
  serviceOrders ServiceOrder[]

  @@map("reported_issues")
}

model ServiceOrder {
  id                 String               @id @default(uuid())
  orderId            String               @unique @map("order_id")
  subject            String               @map("subject")
  description        String               @map("description")
  type               ServiceOrderType     @map("type")
  department         Department
  requester          String
  priority           OrderPriority
  status             OrderStatus
  patrimonyId        String               @map("patrimony_id")
  reportedIssueId    String?              @map("reported_issue_id")
  isExternal         Boolean              @default(false) @map("is_external")
  contactName        String?              @map("contact_name")
  contactPhone       String?              @map("contact_phone")
  serviceRating      Int?                 @map("service_rating")
  ratedAt            DateTime?            @map("rated_at")
  closedAt           DateTime?            @map("closed_at")
  closedById         String?              @map("closed_by_id")
  labEntryAt         DateTime?            @map("lab_entry_at")
  labExitAt          DateTime?            @map("lab_exit_at")
  labDescription     String?              @map("lab_description")
  labTechnicianId    String?              @map("lab_technician_id")
  serviceOrderStatus ServiceOrderStatus[]
  attachment         String?              @map("attachment")
  createdAt          DateTime             @default(now())
  user               User?                @relation(fields: [userId], references: [id])
  userId             String?
  patrimony          Patrimony            @relation(fields: [patrimonyId], references: [id])
  reportedIssue      ReportedIssue?       @relation(fields: [reportedIssueId], references: [id])
  closedBy           User?                @relation("ServiceOrderClosedBy", fields: [closedById], references: [id])
  labTechnician      User?                @relation("ServiceOrderLabTechnician", fields: [labTechnicianId], references: [id])
  historics          Historic[]

  @@map("service_order")
}

model ServiceOrderStatus {
  id             String       @id @default(uuid())
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id])
  serviceOrderId String       @map("service_order_id")
  status         OrderStatus
  note           String?      @map("note")
  technician     User?        @relation(fields: [technicianId], references: [id])
  technicianId   String?      @map("technician_id")
  createdAt      DateTime     @default(now())

  @@map("service_order_status")
}

enum OrderPriority {
  URGENT
  HIGH
  MEDIUM
  LOW
}

enum ServiceOrderType {
  TI
  MAINTENANCE
  SYSTEM
  NETWORK
  INFRASTRUCTURE
  OTHER
}

enum OrderStatus {
  OPEN
  IN_PROGRESS
  IN_LABORATORY
  LAB_COMPLETED
  CLOSED
  CANCELLED
}

enum PatrimonySituation {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum Role {
  ADMIN
  TECHNICIAN
  DEPARTMENT
}

model Log {
  id        String   @id @default(uuid())
  level     LogLevel
  message   String   @map("message")
  context   Json?    @map("context")
  requestId String?  @map("request_id")
  path      String?  @map("path")
  method    String?  @map("method")
  userId    String?  @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("logs")
}

model Historic {
  id        String         @id @default(uuid())
  detail    String         @map("detail")
  action    HistoricAction
  order     ServiceOrder   @relation(fields: [orderId], references: [id])
  orderId   String         @map("order_id")
  createdAt DateTime       @default(now()) @map("created_at")
  user      User?          @relation(fields: [userId], references: [id])
  userId    String?        @map("user_id")

  @@map("historics")
}

enum HistoricAction {
  CREATE
  UPDATE
  CLOSED
  ATTRIBUTED
}

model seedStatus {
  id         String   @id @default(cuid())
  executedAt DateTime @default(now()) @map("executed_at")

  @@map("seed_status")
}

enum LogLevel {
  INFO
  WARNING
  ERROR
}

enum Department {
  CONTROLADORIA_GERAL_DO_MUNICIPIO
  FUNDACAO_DE_DESENVOLVIMENTO_SOCIAL_DE_BELFORD_ROXO
  FUNDACAO_SAUDE_DE_BELFORD_ROXO
  FUNDO_MUNICIPAL_DE_SAUDE
  GABINETE_DO_PREFEITO
  GABINETE_DO_VICE_PREFEITO
  INSTITUTO_DE_PREVIDENCIA_DOS_SERVIDORES_DE_BELFORD_ROXO
  PROCURADORIA_GERAL_DO_MUNICIPIO
  SECRETARIA_DE_COMBATE_A_FOME
  SECRETARIA_MUNICIPAL_DA_CASA_CIVIL
  SECRETARIA_MUNICIPAL_DA_MULHER
  SECRETARIA_MUNICIPAL_DE_ACAO_COMUNITARIA
  SECRETARIA_MUNICIPAL_DE_ADMINISTRACAO
  SECRETARIA_MUNICIPAL_DE_AGRICULTURA
  SECRETARIA_MUNICIPAL_DE_ASSISTENCIA_SOCIAL_E_CIDADANIA
  SECRETARIA_MUNICIPAL_DE_CIENCIA_TECNOLOGIA_E_INOVACAO
  SECRETARIA_MUNICIPAL_DE_COMUNICACAO_SOCIAL
  SECRETARIA_MUNICIPAL_DE_CONSERVACAO
  SECRETARIA_MUNICIPAL_DE_CULTURA
  SECRETARIA_MUNICIPAL_DE_DEFESA_CIVIL
  SECRETARIA_MUNICIPAL_DE_EDUCACAO
  SECRETARIA_MUNICIPAL_DE_ESPORTE_E_LAZER
  SECRETARIA_MUNICIPAL_DE_FAZENDA
  SECRETARIA_MUNICIPAL_DE_GOVERNO
  SECRETARIA_MUNICIPAL_DE_HABITACAO_E_URBANISMO
  SECRETARIA_MUNICIPAL_DE_INDUSTRIA_E_COMERCIO
  SECRETARIA_MUNICIPAL_DE_LICITACOES_E_COMPRAS
  SECRETARIA_MUNICIPAL_DE_MEIO_AMBIENTE_E_SUSTENTABILIDADE
  SECRETARIA_MUNICIPAL_DE_OBRAS_INFRAESTRUTURA_E_SANEAMENTO
  SECRETARIA_MUNICIPAL_DE_ORDEM_PUBLICA
  SECRETARIA_MUNICIPAL_DE_PROTECAO_E_DEFESA_DOS_ANIMAIS
  SECRETARIA_MUNICIPAL_DE_SAUDE
  SECRETARIA_MUNICIPAL_DE_SEGURANCA_PUBLICA
  SECRETARIA_MUNICIPAL_DE_SERVICOS_PUBLICOS
  SECRETARIA_MUNICIPAL_DE_TRABALHO_RENDA_E_ECONOMIA_SOLIDARIA
  SECRETARIA_MUNICIPAL_DE_TRANSPORTES_E_MOBILIDADE_URBANA
  SECRETARIA_MUNICIPAL_DE_TURISMO_E_EVENTOS
  SECRETARIA_MUNICIPAL_DO_IDOSO
  SECRETARIA_MUNICIPAL_ESPECIAL_DO_CHEFE_DE_GABINETE
}
