generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String               @id @default(uuid())
  name                 String
  email                String               @unique
  taxIdentifier        String               @unique @map("tax_identifier")
  password             String
  role                 Role
  department           Department
  isActive             Boolean              @default(true) @map("is_active")
  isFirstAccess        Boolean              @default(true) @map("is_first_access")
  isDeleted            Boolean              @default(false) @map("is_deleted")
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  deletedAt            DateTime?            @map("deleted_at")
  serviceOrders        ServiceOrder[]
  serviceOrderStatuses ServiceOrderStatus[]

  @@map("users")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  email     String
  used      Boolean  @default(false)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

model ServiceOrder {
  id                 String               @id @default(uuid())
  orderId            String               @unique @map("order_id")
  subject            String               @map("subject")
  description        String               @map("description")
  type               ServiceOrderType     @map("type")
  department         Department
  requester          String
  priority           OrderPriority
  serviceOrderStatus ServiceOrderStatus[]
  attachment         String?              @map("attachment")
  createdAt          DateTime             @default(now())
  user               User?                @relation(fields: [userId], references: [id])
  userId             String?
}

model ServiceOrderStatus {
  id             String       @id @default(uuid())
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id])
  serviceOrderId String       @map("service_order_id")
  status         OrderStatus
  note           String?      @map("note")
  technician     User?        @relation(fields: [technicianId], references: [id])
  technicianId   String?      @map("technician_id")
  createdAt      DateTime     @default(now())
}

enum OrderPriority {
  URGENT
  HIGH
  MEDIUM
  LOW
}

enum ServiceOrderType {
  TI
  MAINTENANCE
  SYSTEM
  NETWORK
  INFRASTRUCTURE
  OTHER
}

enum OrderStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum Role {
  ADMIN
  TECHNICIAN
  DEPARTMENT
}

model Log {
  id        String   @id @default(uuid())
  level     LogLevel
  message   String   @map("message")
  context   Json?    @map("context")
  requestId String?  @map("request_id")
  path      String?  @map("path")
  method    String?  @map("method")
  userId    String?  @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("logs")
}

enum LogLevel {
  INFO
  WARNING
  ERROR
}

enum Department {
  CONTROLADORIA_GERAL_DO_MUNICIPIO
  FUNDACAO_DE_DESENVOLVIMENTO_SOCIAL_DE_BELFORD_ROXO
  FUNDACAO_SAUDE_DE_BELFORD_ROXO
