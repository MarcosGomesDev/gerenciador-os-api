{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "plugins": [
      {
        "name": "@nestjs/swagger/plugin"
      }
    ],
    "assets": [
      {
        "include": "src/infrastructure/providers/mail/templates/**/*",
        "outDir": "dist/src/infrastructure/providers/mail/templates"
      },
      {
        "include": "src/modules/service-order/pdf/assets/**/*",
        "outDir": "dist/src/modules/service-order/pdf/assets",
        "watchAssets": true
      }
    ]
  }
}
