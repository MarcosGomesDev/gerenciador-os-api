doctype html
html
  head
    title Recuperação de senha
  body(style="font-family: Arial, sans-serif; padding: 20px;")
    h1(style="color: #333;") Recuperação de Senha
    p Recebemos uma solicitação para redefinir a senha da sua conta.
    if resetLink
      p Clique no botão abaixo para redefinir sua senha:
      p(style="margin: 24px 0;")
        a(href=resetLink style="display: inline-block; padding: 12px 24px; background-color: #1a73e8; color: #fff; text-decoration: none; border-radius: 6px; font-weight: bold;") Redefinir senha
      p(style="color: #666; font-size: 14px;") Ou copie e cole este link no navegador:
      p(style="word-break: break-all; font-size: 14px;") #{resetLink}
    p Use o código abaixo caso precise informar manualmente:
    h2(style="color: #1a73e8;") #{token}
    if expiresAt
      p Este código expira em #{expiresAt} minutos.
    p Se você não solicitou a redefinição de senha, pode ignorar este e-mail com segurança.
